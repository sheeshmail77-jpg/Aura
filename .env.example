# Copy this file to ".env" and fill in your values.
  
  # ── Server ────────────────────────────────────────────────────────────────────
  # Port the server listens on. Most hosts (Render/Railway) set PORT automatically.
  PORT=8080
  
  # ── Ingest token (for the Roblox script) ─────────────────────────────────────
  # The Roblox script must send this value in the "x-ingest-token" header.
  # Leave blank to accept logs from anyone (NOT recommended for public hosting).
  INGEST_TOKEN=TUFFFF31425FW1E2
  
  # Max number of log entries kept in memory (also auto-pruned to 24h).
  MAX_LOGS=1000
  
  # ── Authentication ────────────────────────────────────────────────────────────
  # Strong random secret used to sign JWTs.
  # Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
  # If unset, a random secret is generated on each restart (all sessions invalidated on restart).
  JWT_SECRET=replace-me-with-a-long-random-string
  
  # Owner account credentials — the owner can create/delete viewer logins.
  # Change these before deploying!
  OWNER_USERNAME=sheeshfn5
  OWNER_PASSWORD=Kaylen196!$

# ── Discord Role Bot ─────────────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications — give it Manage Roles permission
DISCORD_BOT_TOKEN=your-bot-token-here

# Your Discord server (guild) ID
DISCORD_GUILD_ID=1517995483719536801
