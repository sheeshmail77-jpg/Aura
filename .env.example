# Copy this file to ".env" (or set these in your host's dashboard).

# Port the server listens on. Most hosts (Render/Railway) set this automatically.
PORT=3000

# Optional shared secret. If set, the Roblox script MUST send the same value
# in the "x-ingest-token" header, otherwise logs are rejected (401).
# Leave blank to accept logs from anyone (not recommended for public hosting).
INGEST_TOKEN=

# Max number of logs kept in memory (also pruned to the last 24h automatically).
MAX_LOGS=1000
